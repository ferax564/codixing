# Rust build output
/target/
**/*.rs.bk
# Cargo.lock is intentionally committed — this workspace produces binaries,
# so lock files ensure reproducible builds for end users.

# Codixing index (generated at runtime)
.codixing/
.codeforge/

# Benchmark output (generated, not committed)
.benchmark_results/

# Embedding model cache (downloaded at runtime, not committed)
.fastembed_cache/

# Test / benchmark data
data/*.redb

# Benchmark cloned repos (large, not committed)
benchmarks/repos/

# Internal tooling and working files
.playwright-mcp/
GTM_Strategy.md

# Screenshot / marketing assets (not part of the source tree)
*.png
*.jpg
*.jpeg
*.gif
!docs/assets/**

# IDE
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
benchmarks/swe_bench_repos/

# Benchmark caches and models (large, generated at runtime)
benchmarks/embed_cache/
benchmarks/models/
benchmarks/reranker_data/
benchmarks/__pycache__/
.claude/worktrees/
