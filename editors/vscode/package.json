{
  "name": "codixing",
  "displayName": "Codixing",
  "description": "Ultra-fast code retrieval engine — search, navigate, and understand code with AI-grade precision",
  "version": "0.16.0",
  "publisher": "ferax564",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferax564/codixing"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "search",
    "AI",
    "MCP",
    "code intelligence",
    "Claude",
    "code retrieval",
    "dependency graph"
  ],
  "activationEvents": [
    "workspaceContains:.codixing",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codixing.indexWorkspace",
        "title": "Codixing: Index Workspace",
        "icon": "$(database)"
      },
      {
        "command": "codixing.syncIndex",
        "title": "Codixing: Sync Index",
        "icon": "$(sync)"
      },
      {
        "command": "codixing.search",
        "title": "Codixing: Search...",
        "icon": "$(search)"
      },
      {
        "command": "codixing.showRepoMap",
        "title": "Codixing: Show Repo Map",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "codixing.showHotspots",
        "title": "Codixing: Show Hotspots",
        "icon": "$(flame)"
      },
      {
        "command": "codixing.showComplexity",
        "title": "Codixing: Show Complexity",
        "icon": "$(graph)"
      },
      {
        "command": "codixing.startDaemon",
        "title": "Codixing: Start Daemon",
        "icon": "$(server-process)"
      },
      {
        "command": "codixing.registerMcpServer",
        "title": "Codixing: Register MCP Server",
        "icon": "$(plug)"
      },
      {
        "command": "codixing.searchView.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codixing.searchView.clear",
        "title": "Clear Results",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codixing",
          "title": "Codixing",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "codixing": [
        {
          "id": "codixing.searchResults",
          "name": "Search Results"
        },
        {
          "id": "codixing.repoMap",
          "name": "Repository Map"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codixing.search",
          "when": "view == codixing.searchResults",
          "group": "navigation"
        },
        {
          "command": "codixing.searchView.clear",
          "when": "view == codixing.searchResults",
          "group": "navigation"
        },
        {
          "command": "codixing.showRepoMap",
          "when": "view == codixing.repoMap",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Codixing",
      "properties": {
        "codixing.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the codixing binary. Leave empty to auto-detect from PATH or common locations."
        },
        "codixing.mcpBinaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the codixing-mcp binary. Leave empty to auto-detect."
        },
        "codixing.lspBinaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the codixing-lsp binary. Leave empty to auto-detect."
        },
        "codixing.lspEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Start the Codixing LSP server for hover, go-to-definition, references, and complexity diagnostics."
        },
        "codixing.autoStartDaemon": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the codixing-mcp daemon when the extension activates."
        },
        "codixing.embeddings": {
          "type": "boolean",
          "default": false,
          "description": "Enable vector embeddings when initializing a new index (slower init, better search quality)."
        },
        "codixing.complexityThreshold": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "description": "Minimum cyclomatic complexity to show as a diagnostic (6 = moderate+, 11 = high+, 26 = critical only)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --out codixing.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
